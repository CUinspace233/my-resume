# If you want to add a mobile number to the header, uncomment the line below and replace the number with your own.
# NEXT_PUBLIC_MOBILE_EN=
# NEXT_PUBLIC_MOBILE_ZH=
NEXT_PUBLIC_BASE_URL=
PRIVATE_RESUME_PASSWORD=your-password
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-5.4
# Optional in local development. Configure Upstash Redis on Vercel for production draft previews.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
